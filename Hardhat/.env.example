## ─── contracts .env ─────────────────────────────────────────────────────────
## Used by hardhat.config.ts + scripts/deploy.ts + scripts/demo-job.ts.
## See docs/LOCAL_SETUP.md §4 + §6 for acquisition recipes.

# Defaults to https://dream-rpc.somnia.network
SOMNIA_TESTNET_RPC=https://dream-rpc.somnia.network

# 0x + 64 hex chars. `cast wallet new`, fund at https://testnet.somnia.network/
DEPLOYER_PRIVATE_KEY=
COACH_PRIVATE_KEY=
AGENT_FORM_PRIVATE_KEY=
AGENT_PRESCRIBER_PRIVATE_KEY=

# Optional override; when unset, deploy.ts deploys Velo's own AgentRegistry.sol
SOMNIA_AGENT_REGISTRY=

# Deploy-time floors (STT)
MIN_JOB_FEE_STT=0.001
MIN_BOUNTY_FEE_STT=0.001

# true to enable hardhat-gas-reporter on `pnpm test`
REPORT_GAS=false

# scripts/demo-job.ts inputs
VIDEO_CID=
ATHLETE_ADDRESS=
JOB_FEE_WEI=

# scripts/register-agents.ts inputs (public addresses)
AGENT_FORM_ADDRESS=
AGENT_PRESCRIBER_ADDRESS=
