# ── Somnia Network ───────────────────────────────────────────────────────────
SOMNIA_RPC_URL=https://dream-rpc.somnia.network
# Optional: WebSocket RPC for real-time event subscription (faster than polling)
# Optional — Somnia WS is flaky (502). Polling is always on; set WATCHER_USE_WEBSOCKET=true to try.
# Use the /ws path per Somnia docs: https://docs.somnia.network
SOMNIA_WS_URL=wss://dream-rpc.somnia.network/ws
WATCHER_USE_WEBSOCKET=false
SOMNIA_CHAIN_ID=50312

# ── Contract Addresses (from deployments/somniaTestnet.json after deploy) ────
ORCHESTRATOR_ADDRESS=
AGENT_REGISTRY_ADDRESS=
ATHLETE_SBT_ADDRESS=
BOUNTY_EXTENSION_ADDRESS=

# ── Agent EOA Private Keys ───────────────────────────────────────────────────
# Fund both at https://testnet.somnia.network/
AGENT_FORM_PRIVATE_KEY=
AGENT_PRESCRIBER_PRIVATE_KEY=

# ── Coach-selectable external analysis model (OPTIONAL) ──────────────────────
# A second, swappable vision model the coach can route a direct job to. It stays
# completely INERT until BOTH EXTERNAL_MODEL_URL and AGENT_EXTERNAL_PRIVATE_KEY
# are set: until then it registers nothing on-chain and the coach's picker only
# offers the default pose model, so existing behaviour is byte-for-byte unchanged.
# Endpoint of the external model (HTTP). Leave blank to disable.
EXTERNAL_MODEL_URL=
# Optional bearer token sent as `Authorization: Bearer <key>`.
EXTERNAL_MODEL_API_KEY=
# Dedicated EOA for this agent — fund at https://testnet.somnia.network/
AGENT_EXTERNAL_PRIVATE_KEY=
# Canonical skill name this model advertises (hashed like every other skill).
EXTERNAL_MODEL_SKILL=vision.serve
# Display name shown in the on-chain agent registry / coach UI.
EXTERNAL_MODEL_NAME=Velo Serve Analyst
# Per-call HTTP timeout (ms).
EXTERNAL_MODEL_TIMEOUT_MS=120000

# ── Somnia native Agentic L1 (SomniaAgents platform) ─────────────────────────
# When enabled, every AI verdict is produced by Somnia's native LLM Inference
# agent (consensus-verified, with an on-chain receipt) and falls back to Groq
# automatically on timeout / unavailability / insufficient runners.
SOMNIA_AGENTS_ENABLED=true
# SomniaAgents (IAgentRequester) platform contract:
#   Testnet (50312): 0x037Bb9C718F3f7fe5eCBDB0b600D607b52706776
#   Mainnet (5031):  0x5E5205CF39E766118C01636bED000A54D93163E6
SOMNIA_AGENTS_CONTRACT=0x037Bb9C718F3f7fe5eCBDB0b600D607b52706776
# VeloAgentRelay address (from deployments/somniaTestnet.json after `deploy.ts`).
# REQUIRED for the native on-chain path: the platform delivers an agent's result
# ONLY to the requester's on-chain callback, so the relay IS that callback and
# re-emits the result for the runner to read. Without it, the runner skips the
# native request entirely (no wasted STT) and uses Groq directly.
SOMNIA_AGENT_RELAY_ADDRESS=
# Live agent IDs from https://agents.testnet.somnia.network/ (REQUIRED for native path)
SOMNIA_LLM_AGENT_ID=
# JSON API Request agent (docs oracle example id); used for on-chain data lookups
SOMNIA_JSON_API_AGENT_ID=13174292974160097713
# Deposit sizing: deposit = getRequestDeposit() + pricePerAgent × subcommitteeSize
SOMNIA_AGENTS_SUBCOMMITTEE=3
# Per-agent reward MUST clear the agent's per-type price or runners skip the
# request. LLM Inference = 0.07 STT today (gas-fees doc). 0.03 underfunds it.
SOMNIA_AGENTS_PRICE_PER_AGENT_WEI=70000000000000000
# Local polling timeout before falling back to Groq (ms) + poll interval (ms).
# On-chain LLM consensus can take >1 min; poll briskly to read the result before
# the platform deletes the finalized request from storage.
SOMNIA_AGENTS_TIMEOUT_MS=120000
SOMNIA_AGENTS_POLL_MS=1000
# On-chain request deadline buffer (seconds)
SOMNIA_AGENTS_DEADLINE_SEC=300
# Public consensus-receipt viewer base URL (linked from the UI)
SOMNIA_AGENTS_RECEIPT_URL=https://agents.testnet.somnia.network

# ── AI Models (fallback path when native agents are unavailable) ─────────────
GROQ_API_KEY=
GROQ_MODEL=llama-3.3-70b-versatile
# Optional fallbacks (plug in key to activate)
# OPENAI_API_KEY=
# OPENAI_MODEL=gpt-4o-mini
# ANTHROPIC_API_KEY=
# ANTHROPIC_MODEL=claude-haiku-3-5

# ── IPFS / Pinata ────────────────────────────────────────────────────────────
# Admin JWT from Pinata → API Keys. Must include org:files:write for sign-upload.
PINATA_JWT=
PINATA_GATEWAY=https://gateway.pinata.cloud
# If no PINATA_JWT, reports use a deterministic local:sha256 CID (demo mode)

# ── Vision Engine (velo-engine Python sidecar) ───────────────────────────────
VISION_ENGINE_URL=http://localhost:8000
# Set to "mock" to skip the video engine entirely and use synthetic telemetry
VISION_MODE=live

# ── API Server ───────────────────────────────────────────────────────────────
API_PORT=3001
API_SECRET=change-me-in-production
# JWT expiry for upload session tokens (seconds)
SESSION_TTL=3600

# ── Supabase (optional — receipts stored in-memory if not set) ───────────────
# SUPABASE_URL=
# SUPABASE_SERVICE_KEY=

# ── Polling fallback (used when WS is unavailable) ───────────────────────────
POLL_INTERVAL_MS=2000
# Block number to start watching from (0 = latest)
START_BLOCK=0
