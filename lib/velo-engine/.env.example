# Velo Vision Engine — environment variables

# Host/port (Koyeb / Render inject $PORT automatically)
HOST=0.0.0.0
PORT=8000

# Log level: DEBUG, INFO, WARNING, ERROR
LOG_LEVEL=INFO

# ── Analysis backend ─────────────────────────────────────────────────────────
# Which pose estimation backend to use.
#
#   mediapipe  (default) — Google MediaPipe Pose, no extra setup needed.
#   custom               — Your own model.  See src/analyzer_custom.py for the
#                          implementation guide, then set CUSTOM_MODEL_PATH.
#
ANALYZER_BACKEND=mediapipe

# Path to your custom model weights file, relative to the container WORKDIR
# (/app inside Docker, which is the velo-engine root directory).
# Only read when ANALYZER_BACKEND=custom.
# Place the file inside custom_models/ — that directory is committed empty so
# the path always exists, but the weights themselves are gitignored.
# CUSTOM_MODEL_PATH=custom_models/model.onnx

# ── MediaPipe tuning (only applies when ANALYZER_BACKEND=mediapipe) ──────────

# Max video duration to analyze (seconds). Videos longer than this are truncated.
MAX_VIDEO_DURATION_S=45

# MediaPipe model complexity: 0=lite (fastest), 1=full (recommended), 2=heavy
MEDIAPIPE_MODEL_COMPLEXITY=1
