# Velo Vision Engine — environment variables

# Host/port (Koyeb / local)
HOST=0.0.0.0
PORT=8000

# Optional: log level (DEBUG, INFO, WARNING, ERROR)
LOG_LEVEL=INFO

# Optional: max video duration to analyze (seconds)
MAX_VIDEO_DURATION_S=45

# Optional: MediaPipe model complexity (0=lite, 1=full, 2=heavy)
# Use 0 for fastest, 1 for balanced (recommended), 2 for best accuracy
MEDIAPIPE_MODEL_COMPLEXITY=1
