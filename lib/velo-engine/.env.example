# Velo Vision Engine — environment variables

# Host/port (Koyeb / Render / local)
HOST=0.0.0.0
PORT=8000

# Optional: log level (DEBUG, INFO, WARNING, ERROR)
LOG_LEVEL=INFO

# Optional: max video duration to analyze (seconds)
MAX_VIDEO_DURATION_S=45

# ── Tier-1 pose engine ────────────────────────────────────────────────
# "yolo"      → YOLO11-pose (going-forward, deterministic Tier-1)   [default]
# "mediapipe" / "custom" → DEMOTED this cycle (factory raises 501).
# Legacy alias ANALYZER_BACKEND is still read if VISION_ENGINE is unset.
VISION_ENGINE=yolo

# YOLO weights: "yolo11s-pose.pt" (stock COCO-17, auto-downloaded) or a path to
# our fine-tuned tennis checkpoint, e.g. /app/weights/velo-pose-best.pt
YOLO_WEIGHTS=yolo11s-pose.pt

# Per-keypoint confidence floor. Angles depending on a keypoint below this are
# NOT emitted (anti-hallucination on occluded joints). 0.0–1.0.
KP_CONF_MIN=0.5

# YOLO person detection confidence. Lower than KP_CONF_MIN because track-level
# subject selection can tolerate weak boxes before keypoint confidence gating.
YOLO_DET_CONF_MIN=0.1

# Max bytes accepted from a remote video URL before returning 422.
MAX_VIDEO_BYTES=209715200

# ── v2 signal layer ───────────────────────────────────────────────────
# Pass-0 CFR normalization (ffmpeg). Fixes VFR timestamps + frame-seek and is the
# on-chain determinism anchor. Set 0 only if ffmpeg is unavailable. [default 1]
NORMALIZE_CFR=1
# Cap the CFR target fps (down-normalizes 120/240fps phone clips). [default 60]
CFR_MAX_FPS=60
# Pass-2 dense re-decode inside stroke windows — lifts effective fps so the coarse
# hips-before-arm hand-off becomes resolvable. Heavier on weak CPUs (see Koyeb
# latency risk); falls back to the coarse pass on failure. Set 0 to disable. [default 1]
DENSE_STROKE_WINDOW=1

# Demo/Tier-2 requests should send emit_keyframes=true and keyframe_format=base64.
# Engine also accepts keyframe_format=none; URL/IPFS pinning is reserved for the
# Pinata-backed integration path.

# ── Legacy MediaPipe (only used when VISION_ENGINE=mediapipe) ──────────
# 0=lite, 1=full (recommended), 2=heavy
MEDIAPIPE_MODEL_COMPLEXITY=1
