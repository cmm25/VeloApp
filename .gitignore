# ── Replit auto-attached files ───────────────────────────────────────────────
attached_assets/
.local/

# ── Node / TypeScript ────────────────────────────────────────────────────────
node_modules/
dist/
build/
*.tsbuildinfo
.npm

# ── Python ───────────────────────────────────────────────────────────────────
__pycache__/
*.py[cod]
*.pyo
.venv/
venv/
*.egg-info/
.eggs/
dist/
*.dist-info/

# ── Environment & secrets ────────────────────────────────────────────────────
.env
.env.local
.env.*.local
# keep .env.example files (they are templates, not secrets)
!.env.example

# ── Hardhat / Foundry ────────────────────────────────────────────────────────
Hardhat/artifacts/
Hardhat/cache/
Hardhat/typechain-types/
Hardhat/coverage/
Hardhat/coverage.json

# ── OS & editor ──────────────────────────────────────────────────────────────
.DS_Store
Thumbs.db
*.swp
*.swo
.idea/
.vscode/
*.code-workspace

# ── Logs ────────────────────────────────────────────────────────────────────
*.log
logs/
npm-debug.log*
yarn-debug.log*
yarn-error.log*

# ── Misc ─────────────────────────────────────────────────────────────────────
*.pdf
*.zip
*.tar.gz
tmp/
temp/

# ── Replit (environment config — kept local, not committed) ───────────────────
.replit
replit.nix

# ── Agent memory (local, not committed) ───────────────────────────────────────
.agents/

# ── Reference folders (anchored to the repo root so nested project dirs like
#    Hardhat/scripts/ and docs/ are NOT swallowed by these blanket rules) ─────
/scripts/
/reference-files-eshaan/
/docs/

# ── Local ML envs, datasets, model weights & run outputs ─────────────────────
#    Large, machine-generated or downloaded — kept on disk, never committed.
#    (Nothing here is deleted; these rules just stop git/VSCode showing them.)
.ls-venv/
.venv-*/
# model weights (e.g. yolo11s-pose.pt)
*.pt
# training run outputs
runs/
# pose visualisation overlays
lib/velo-engine/overlays/
# training scripts, datasets & local envs
lib/velo-training/
# local e2e verification harness
lib/velo-agents/verify_*.ts

# ── Local tool / deploy configs ──────────────────────────────────────────────
.claude/
.vercel/
